<Application x:Class="MeetingRecorder.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:tb="clr-namespace:H.NotifyIcon;assembly=H.NotifyIcon.Wpf"
             xmlns:converters="clr-namespace:MeetingRecorder.Converters"
             xmlns:properties="clr-namespace:MeetingRecorder"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <converters:EnumToBoolConverter x:Key="EnumToBoolConverter" />

        <tb:TaskbarIcon x:Key="NotifyIcon"
                        ToolTipText="{Binding StatusText}">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}">
                    <MenuItem Header="{Binding ShowStatusWindowText}" Click="Show_Click" />
                    <MenuItem Header="{Binding OpenFolderText}"
                              Command="{Binding OpenFolderCommand}" />
                    <Separator />
                    <MenuItem Header="{Binding ExitButtonText}"
                              Command="{Binding ExitCommand}" />
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>
    </Application.Resources>
</Application>
