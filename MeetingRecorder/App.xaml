<Application x:Class="MeetingRecorder.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:tb="clr-namespace:H.NotifyIcon;assembly=H.NotifyIcon.Wpf"
             xmlns:viewmodels="clr-namespace:MeetingRecorder.ViewModels"
             xmlns:converters="clr-namespace:MeetingRecorder.Converters"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <viewmodels:MainViewModel x:Key="MainViewModel" />
        <converters:EnumToBoolConverter x:Key="EnumToBoolConverter" />
        
        <tb:TaskbarIcon x:Key="NotifyIcon"
                        ToolTipText="{Binding StatusText, Source={StaticResource MainViewModel}}">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Show Status Window" Click="Show_Click" />
                    <MenuItem Header="Open Recordings Folder" 
                              Command="{Binding OpenFolderCommand, Source={StaticResource MainViewModel}}" />
                    <Separator />
                    <MenuItem Header="Exit" 
                              Command="{Binding ExitCommand, Source={StaticResource MainViewModel}}" />
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>
    </Application.Resources>
</Application>
