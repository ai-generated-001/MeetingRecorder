<Window x:Class="MeetingRecorder.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:MeetingRecorder.Models"
        xmlns:viewmodels="clr-namespace:MeetingRecorder.ViewModels"
        xmlns:properties="clr-namespace:MeetingRecorder"
        Title="{Binding AppTitle}" Height="400" Width="540"
        MinHeight="350" MinWidth="420"
        WindowStartupLocation="CenterScreen"
        Background="#FFF6F8FB"
        Icon="Resources/icon.ico">
    <Grid Margin="20">
        <Border Background="White" CornerRadius="12" Padding="18" BorderBrush="#FFE4E8EF" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="{Binding HeaderTitle}" FontSize="20" FontWeight="SemiBold" Foreground="#FF1F2937"/>
                <TextBlock Grid.Row="1" Margin="0,6,0,14" Text="{Binding AppDescription}"
                           TextWrapping="Wrap" Foreground="#FF6B7280"/>

                <Border Grid.Row="2" Background="#FFF9FAFB" BorderBrush="#FFE5E7EB" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="{Binding StatusLabel}" FontWeight="SemiBold" Foreground="#FF374151"/>
                            <TextBlock Text="{Binding StatusText}" FontSize="16" FontWeight="SemiBold" Margin="0,4,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#FF1D4ED8"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Status}" Value="{x:Static viewmodels:AppStatus.Recording}">
                                                <Setter Property="Foreground" Value="#FFB91C1C"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>

                        <Ellipse Grid.Column="1" Width="14" Height="14" VerticalAlignment="Center" Margin="10,0,0,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#FF2563EB"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Status}" Value="{x:Static viewmodels:AppStatus.Recording}">
                                            <Setter Property="Fill" Value="#FFDC2626"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                    </Grid>
                </Border>

                <Grid Grid.Row="3" VerticalAlignment="Top" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding OutputFormatLabel}" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#FF374151"/>
                        <RadioButton Content="MP3" VerticalAlignment="Center" Margin="0,0,14,0"
                                     IsChecked="{Binding OutputFormat, Converter={StaticResource EnumToBoolConverter}, ConverterParameter={x:Static models:OutputFormat.Mp3}}"/>
                        <RadioButton Content="WAV" VerticalAlignment="Center"
                                     IsChecked="{Binding OutputFormat, Converter={StaticResource EnumToBoolConverter}, ConverterParameter={x:Static models:OutputFormat.Wav}}"/>
                    </StackPanel>

                    <Button Grid.Column="1" Content="{Binding SettingsButtonText}" Command="{Binding OpenSettingsCommand}" Padding="10,5" MinWidth="90"/>
                </Grid>

                <Grid Grid.Row="4" Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,8">
                        <Button Content="{Binding StartMonitoringText}" Command="{Binding StartMonitoringCommand}" Margin="0,0,8,0" Padding="14,7" Width="140"/>
                        <Button Content="{Binding StopMonitoringText}" Command="{Binding StopMonitoringCommand}" Margin="0,0,8,0" Padding="14,7" Width="140"/>
                        <Button Content="{Binding StopRecordingText}" Command="{Binding StopRecordingCommand}" Padding="14,7" Width="130"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="{Binding OpenFolderText}" Command="{Binding OpenFolderCommand}" Margin="0,0,8,0" Padding="14,7" Width="190"/>
                        <Button Content="{Binding ExitButtonText}" Command="{Binding ExitCommand}" Padding="14,7" Width="90"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
