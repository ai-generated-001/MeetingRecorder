<Window x:Class="MeetingRecorder.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:MeetingRecorder.Models"
        xmlns:viewmodels="clr-namespace:MeetingRecorder.ViewModels"
        xmlns:properties="clr-namespace:MeetingRecorder"
        Title="{Binding AppTitle}" 
        Height="450" 
        Width="560"
        MinHeight="450" 
        MinWidth="560"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundBrush}"
        Icon="Resources/icon.ico"
        FontFamily="Segoe UI"
        FontSize="13"
        Foreground="{DynamicResource WindowForegroundBrush}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <!-- Base Button Style -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ButtonBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource ButtonForegroundBrush}"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" CornerRadius="6" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource ButtonMouseOverBackgroundBrush}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource ButtonMouseOverBorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource ButtonPressedBackgroundBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource ControlDisabledBackgroundBrush}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource ControlDisabledBorderBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource ControlDisabledForegroundBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary Button Style -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{DynamicResource PrimaryButtonBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryButtonBorderBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryButtonForegroundBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" CornerRadius="6" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource PrimaryButtonMouseOverBackgroundBrush}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource PrimaryButtonMouseOverBorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource PrimaryButtonPressedBackgroundBrush}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource PrimaryButtonPressedBorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource PrimaryButtonDisabledBackgroundBrush}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource PrimaryButtonDisabledBorderBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryButtonForegroundBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Danger Button Style -->
        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{DynamicResource DangerButtonBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DangerButtonBorderBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource DangerButtonForegroundBrush}"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" CornerRadius="6" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource DangerButtonBackgroundBrush}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource DangerButtonMouseOverBorderBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource DangerButtonMouseOverForegroundBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource DangerButtonPressedBackgroundBrush}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource DangerButtonPressedBorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource ControlDisabledBackgroundBrush}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource ControlDisabledBorderBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource ControlDisabledForegroundBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- RadioButton Style -->
        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="{DynamicResource WindowForegroundBrush}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8,0,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid x:Name="templateRoot" Background="Transparent" SnapsToDevicePixels="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid x:Name="radioGrid" Height="18" Width="18" VerticalAlignment="Center">
                                <Border x:Name="radioBorder" BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="1.5" Background="{DynamicResource ControlBackgroundBrush}" CornerRadius="9"/>
                                <Ellipse x:Name="radioGlyph" Fill="{DynamicResource PrimaryButtonBackgroundBrush}" Width="8" Height="8" Visibility="Collapsed"/>
                            </Grid>
                            <ContentPresenter x:Name="contentPresenter" Grid.Column="1" Focusable="False" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" Margin="{TemplateBinding Padding}" RecognizesAccessKey="True" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="true">
                                <Setter TargetName="radioBorder" Property="BorderBrush" Value="{DynamicResource ControlFocusedBorderBrush}"/>
                                <Setter TargetName="radioBorder" Property="Background" Value="{DynamicResource SelectionBackgroundBrush}"/>
                                <Setter TargetName="radioGlyph" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="radioBorder" Property="BorderBrush" Value="{DynamicResource ControlMouseOverBorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter TargetName="radioBorder" Property="Background" Value="{DynamicResource ControlDisabledBackgroundBrush}"/>
                                <Setter TargetName="radioBorder" Property="BorderBrush" Value="{DynamicResource ControlDisabledBorderBrush}"/>
                                <Setter TargetName="radioGlyph" Property="Fill" Value="{DynamicResource ControlDisabledForegroundBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource ControlDisabledForegroundBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="12" Padding="20" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <!-- Title & description -->
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <!-- Status card -->
                    <RowDefinition Height="Auto"/>
                    <!-- Output format and Settings -->
                    <RowDefinition Height="Auto"/>
                    <!-- Divider -->
                    <RowDefinition Height="Auto"/>
                    <!-- Control buttons -->
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="{Binding HeaderTitle}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Grid.Row="1" Margin="0,6,0,16" Text="{Binding AppDescription}" TextWrapping="Wrap" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>

                <!-- Status Card -->
                <Border Grid.Row="2" Background="{DynamicResource DriveCardBackgroundBrush}" BorderBrush="{DynamicResource DriveCardBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0">
                            <TextBlock Text="{Binding StatusLabel}" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                            <TextBlock Text="{Binding StatusText}" FontSize="16" FontWeight="Bold" Margin="0,4,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource StatusIdleBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding StatusCategory}" Value="{x:Static viewmodels:StatusMessageCategory.Detecting}">
                                                <Setter Property="Foreground" Value="{DynamicResource StatusDetectingBrush}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StatusCategory}" Value="{x:Static viewmodels:StatusMessageCategory.Recording}">
                                                <Setter Property="Foreground" Value="{DynamicResource StatusRecordingBrush}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StatusCategory}" Value="{x:Static viewmodels:StatusMessageCategory.Uploading}">
                                                <Setter Property="Foreground" Value="{DynamicResource StatusUploadingBrush}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StatusCategory}" Value="{x:Static viewmodels:StatusMessageCategory.UploadSuccess}">
                                                <Setter Property="Foreground" Value="{DynamicResource StatusUploadSuccessBrush}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StatusCategory}" Value="{x:Static viewmodels:StatusMessageCategory.UploadError}">
                                                <Setter Property="Foreground" Value="{DynamicResource StatusUploadErrorBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>

                        <!-- Glowing status badge -->
                        <Ellipse Grid.Row="0" Grid.Column="1" Width="12" Height="12" VerticalAlignment="Center" Margin="10,0,0,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{DynamicResource BadgeIdleBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding StatusCategory}" Value="{x:Static viewmodels:StatusMessageCategory.Detecting}">
                                            <Setter Property="Fill" Value="{DynamicResource BadgeDetectingBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding StatusCategory}" Value="{x:Static viewmodels:StatusMessageCategory.Recording}">
                                            <Setter Property="Fill" Value="{DynamicResource BadgeRecordingBrush}"/>
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard Name="PulsingBadge">
                                                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                         From="1.0" To="0.3" Duration="0:0:0.7"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <StopStoryboard BeginStoryboardName="PulsingBadge"/>
                                            </DataTrigger.ExitActions>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding StatusCategory}" Value="{x:Static viewmodels:StatusMessageCategory.Uploading}">
                                            <Setter Property="Fill" Value="{DynamicResource BadgeUploadingBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding StatusCategory}" Value="{x:Static viewmodels:StatusMessageCategory.UploadSuccess}">
                                            <Setter Property="Fill" Value="{DynamicResource BadgeUploadSuccessBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding StatusCategory}" Value="{x:Static viewmodels:StatusMessageCategory.UploadError}">
                                            <Setter Property="Fill" Value="{DynamicResource BadgeUploadErrorBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>

                        <!-- Organizing progress -->
                        <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="0,10,0,0" Visibility="{Binding ShowOrganizeProgress, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="{Binding OrganizeStatusText}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4" TextWrapping="Wrap"/>
                            <ProgressBar Value="{Binding OrganizeProgressValue}" Minimum="0" Maximum="100" Height="8"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Format & Settings Row -->
                <Grid Grid.Row="3" VerticalAlignment="Top" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding OutputFormatLabel}" VerticalAlignment="Center" Margin="0,0,12,0" Foreground="{DynamicResource TextSecondaryBrush}" FontWeight="Medium"/>
                        <RadioButton Content="MP3" VerticalAlignment="Center" Margin="0,0,16,0"
                                     IsChecked="{Binding OutputFormat, Converter={StaticResource EnumToBoolConverter}, ConverterParameter={x:Static models:OutputFormat.Mp3}}"/>
                        <RadioButton Content="WAV" VerticalAlignment="Center"
                                     IsChecked="{Binding OutputFormat, Converter={StaticResource EnumToBoolConverter}, ConverterParameter={x:Static models:OutputFormat.Wav}}"/>
                    </StackPanel>

                    <Button Grid.Column="1" Content="{Binding SettingsButtonText}" Command="{Binding OpenSettingsCommand}" Width="90"/>
                </Grid>

                <!-- Separator -->
                <Border Grid.Row="4" BorderBrush="{DynamicResource SeparatorBrush}" BorderThickness="0,1,0,0" Margin="0,4,0,16" SnapsToDevicePixels="True"/>

                <!-- Action buttons -->
                <Grid Grid.Row="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,10">
                        <Button Content="{Binding StartMonitoringText}" Command="{Binding StartMonitoringCommand}" Margin="0,0,8,0" Width="140"/>
                        <Button Content="{Binding StopMonitoringText}" Command="{Binding StopMonitoringCommand}" Margin="0,0,8,0" Width="140"/>
                        <Button Content="{Binding StopRecordingText}" Command="{Binding StopRecordingCommand}" Style="{StaticResource DangerButtonStyle}" Width="130"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="{Binding OpenFolderText}" Command="{Binding OpenFolderCommand}" Margin="0,0,8,0" Width="190"/>
                        <Button Content="{Binding UploadToDriveText}" Command="{Binding ManualUploadCommand}" Margin="0,0,8,0" Width="160"/>
                        <Button Content="{Binding ExitButtonText}" Command="{Binding ExitCommand}" Width="90"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
