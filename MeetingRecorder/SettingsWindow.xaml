<Window x:Class="MeetingRecorder.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:properties="clr-namespace:MeetingRecorder"
        Title="{x:Static properties:Resources.Settings}"
        Height="230"
        Width="560"
        MinHeight="230"
        MinWidth="560"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{x:Static properties:Resources.RecordingsFolder}" Margin="0,0,0,8" FontWeight="SemiBold"/>

        <Grid Grid.Row="1" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="OutputDirectoryTextBox" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <Button Grid.Column="1" Content="{x:Static properties:Resources.Browse}" Width="90" Padding="10,5" Click="Browse_Click"/>
        </Grid>

        <TextBlock Grid.Row="2" Text="{x:Static properties:Resources.UiLanguageLabel}" Margin="0,0,0,8" FontWeight="SemiBold"/>

        <ComboBox x:Name="LanguageComboBox" Grid.Row="3" Margin="0,0,0,14"
                  DisplayMemberPath="DisplayName"
                  SelectedValuePath="Code"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,0">
            <Button Content="{x:Static properties:Resources.Cancel}" Width="90" Padding="10,5" Margin="0,0,8,0" IsCancel="True"/>
            <Button Content="{x:Static properties:Resources.Save}" Width="90" Padding="10,5" IsDefault="True" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
